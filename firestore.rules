rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: employees
    // Document ID: {employeeId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - photo: string (optional)
    //   - active: boolean (required)
    //
    // Collection: history
    // Document ID: {historyId}
    // Fields:
    //   - id: string (required)
    //   - date: string (required, date-time)
    //   - order: list (required)
    //   - responsibleAdmin: string (optional)
    //
    // Document: /config/settings
    // Fields:
    //   - title: string (required)
    //   - bannerUrl: string (required)
    //   - logoUrl: string (required)
    //   - nextSortDate: string (optional)
    //
    // Document: /config/currentOrder
    // Fields:
    //   - order: list (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: ['admin', 'user'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "l2xbrasil@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidEmployee(data) {
      return hasRequiredFields(['id', 'name', 'active']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.active is bool &&
             (!('photo' in data) || (data.photo is string && data.photo.size() < 1000000));
    }

    function isValidHistory(data) {
      return hasRequiredFields(['id', 'date', 'order']) &&
             data.id is string &&
             data.date is string &&
             data.order is list &&
             (!('responsibleAdmin' in data) || data.responsibleAdmin is string);
    }

    function isValidConfig(data) {
      return hasRequiredFields(['title', 'bannerUrl', 'logoUrl']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.bannerUrl is string && data.bannerUrl.size() < 1000000 &&
             data.logoUrl is string && data.logoUrl.size() < 1000000;
    }

    function isValidCurrentOrder(data) {
      return hasRequiredFields(['order']) &&
             data.order is list;
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /employees/{employeeId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidEmployee(request.resource.data);
      allow delete: if isAdmin();
    }

    match /history/{historyId} {
      allow read: if true;
      allow create: if isAdmin() && isValidHistory(request.resource.data);
      allow update: if isAdmin() && isValidHistory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /config/settings {
      allow read: if true;
      allow write: if isAdmin() && isValidConfig(request.resource.data);
    }

    match /config/currentOrder {
      allow read: if true;
      allow write: if isAdmin() && isValidCurrentOrder(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
